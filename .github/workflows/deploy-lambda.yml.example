name: Deploy Lambda

on:
  push:
    branches:
      - main
      - dev

permissions:
  contents: read

jobs:
  deploy:
    runs-on: ubuntu-latest

    env:
      GO_VERSION: "1.22"
      BUILD_DIR: build
      BINARY_NAME: bootstrap
      AWS_REGION: ${{ secrets.AWS_REGION }}

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Go
        uses: actions/setup-go@v5
        with:
          go-version: ${{ env.GO_VERSION }}

      - name: Build Lambda binary
        run: |
          GOOS=linux GOARCH=amd64 go build -o $BUILD_DIR/$BINARY_NAME ./lambda
          cd $BUILD_DIR && zip function.zip $BINARY_NAME

      - name: Configure AWS credentials
        uses: aws-actions/configure-aws-credentials@v4
        with:
          aws-access-key-id: ${{ secrets.AWS_ACCESS_KEY_ID }}
          aws-secret-access-key: ${{ secrets.AWS_SECRET_ACCESS_KEY }}
          aws-region: ${{ env.AWS_REGION }}

      - name: Set function name from branch
        id: names
        run: |
          if [ "${GITHUB_REF##*/}" = "main" ]; then
            echo "FUNCTION_NAME=lambda-go-server-boilerplate-prod" >> $GITHUB_OUTPUT
          else
            echo "FUNCTION_NAME=lambda-go-server-boilerplate-dev" >> $GITHUB_OUTPUT
          fi

      - name: Deploy to Lambda
        run: |
          aws lambda update-function-code \
            --function-name "${{ steps.names.outputs.FUNCTION_NAME }}" \
            --zip-file fileb://$BUILD_DIR/function.zip

